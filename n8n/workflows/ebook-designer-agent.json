        "jsCode": "const productId   = $('Parse HTML Output').item.json.productId;\nconst productSlug = $('Parse HTML Output').item.json.productSlug;\n\nconst specItems = $('Fetch Product Spec').all();\nconst specRaw = specItems.length > 0 ? specItems[0].json : [];\nconst product = Array.isArray(specRaw) ? (specRaw[0] || {}) : specRaw;\n\nconst title = product.name || product.title || 'Ebook';\nconst productType = (product.type || '').replace(/_/g, ' ');\n\nconst supabaseUrl = 'https://illcsxpidmluhdwgygwf.supabase.co';\nconst pdfUrl  = supabaseUrl + '/storage/v1/object/public/templates/ebooks/' + productId + '/' + productSlug + '.pdf';\nconst htmlUrl = supabaseUrl + '/storage/v1/object/public/templates/ebooks/' + productId + '/' + productSlug + '.html';\n\nconst html = '<div style=\\\"max-width:600px;margin:0 auto;font-family:Arial,sans-serif;color:#333;\\\">'\n  + '<div style=\\\"background:#0A0A0A;padding:24px;text-align:center;\\\">'\n  + '<span style=\\\"color:#C8F53A;font-size:18px;letter-spacing:3px;font-weight:bold;\\\">CIPHER STUDIO</span>'\n  + '</div>'\n  + '<div style=\\\"padding:24px;\\\">'\n  + '<h2 style=\\\"margin:0 0 8px;font-size:20px;color:#0A0A0A;\\\">' + title + '</h2>'\n  + '<p style=\\\"color:#666;margin:0 0 20px;font-size:14px;\\\">Your ebook has been designed and is ready for review.</p>'\n  + '<table style=\\\"width:100%;margin:0 0 20px;\\\">'\n  + '<tr><td style=\\\"padding:8px 0;font-size:14px;color:#888;\\\">Type</td><td style=\\\"padding:8px 0;font-size:14px;color:#333;\\\">' + productType + '</td></tr>'\n  + '<tr><td style=\\\"padding:8px 0;font-size:14px;color:#888;\\\">Status</td><td style=\\\"padding:8px 0;font-size:14px;color:#333;\\\">Ready for review</td></tr>'\n  + '</table>'\n  + '<a href=\\\"' + pdfUrl + '\\\" style=\\\"display:block;background:#C8F53A;color:#0A0A0A;text-align:center;padding:14px;font-size:14px;font-weight:bold;text-decoration:none;border-radius:4px;margin:0 0 12px;\\\">Download PDF</a>'\n  + '<a href=\\\"' + htmlUrl + '\\\" style=\\\"display:block;background:#1C1C1C;color:#C8F53A;text-align:center;padding:14px;font-size:14px;font-weight:bold;text-decoration:none;border-radius:4px;\\\">Preview HTML</a>'\n  + '</div>'\n  + '<div style=\\\"padding:16px 24px;border-top:1px solid #eee;text-align:center;\\\">'\n  + '<span style=\\\"font-size:11px;color:#aaa;\\\">Cipher Studio LLC \\u00b7 Automated notification</span>'\n  + '</div>'\n  + '</div>';\n\nreturn [{ json: {\n  subject: 'Ebook Ready: ' + title,\n  html,\n  pdfUrl,\n  htmlUrl,\n  productId\n} }];"
