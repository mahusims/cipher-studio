    {
      "parameters": {
        "jsCode": "const raw = ($json.content || []).find(b => b.type === 'text')?.text || '';\n\nconst clean = raw.trim().startsWith('```')\n  ? raw.trim().replace(/^```[a-z]*\\n?/, '').replace(/\\n?```$/, '').trim()\n  : raw.trim();\n\nconst productId   = $('Webhook Trigger').first().json.body.product_id;\nconst productSlug = $('Build Claude Request Body').first().json.productSlug;\n\nreturn [{ json: { html: clean, productId, productSlug } }];"
      },
