    {
      "id": "qa-build-revision-email",
      "name": "Build QA Revision Email",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2840,
        800
      ],
      "parameters": {
        "jsCode": "const qa = $('Parse QA Result').first().json;\nconst { product, productId, overall_score, content_score, formatting_score, brand_score, market_score, issues, revision_instructions, recommendation } = qa;\nconst title = product.name || 'Unknown Ebook';\nconst retryNum = (product.qa_retry_count || 0) + 1;\n\nconst scoreRow = (label, score) =>\n  '<tr><td style=\"padding:6px 0;font-size:14px;color:#888;\">' + label + '</td>'\n  + '<td style=\"padding:6px 0;font-size:14px;font-weight:bold;color:' + (score >= 7 ? '#333' : '#c00') + ';\">' + (score || 0) + '/10' + (score < 7 ? ' ✗' : '') + '</td></tr>';\n\nconst html = '<div style=\"max-width:600px;margin:0 auto;font-family:Arial,sans-serif;color:#333;\">'\n  + '<div style=\"background:#0A0A0A;padding:24px;text-align:center;\">'\n  + '<span style=\"color:#C8F53A;font-size:18px;letter-spacing:3px;font-weight:bold;\">CIPHER STUDIO</span>'\n  + '</div>'\n  + '<div style=\"padding:24px;\">'\n  + '<h2 style=\"margin:0 0 4px;color:#c00;\">QA Revision #' + retryNum + '</h2>'\n  + '<h3 style=\"margin:0 0 16px;font-size:16px;color:#333;font-weight:normal;\">' + title + '</h3>'\n  + '<p style=\"margin:0 0 20px;font-size:16px;font-weight:bold;color:#fff;background:#c00;padding:12px 16px;border-radius:4px;\">Overall Score: ' + (overall_score || 0) + '/10 — FAILED</p>'\n  + '<table style=\"width:100%;margin:0 0 20px;\">'\n  + scoreRow('Content Quality', content_score)\n  + scoreRow('Formatting', formatting_score)\n  + scoreRow('Brand Consistency', brand_score)\n  + scoreRow('Market Readiness', market_score)\n  + '</table>'\n  + (issues && issues.length ? '<h4 style=\"margin:0 0 8px;color:#c00;\">Issues Found</h4><ul style=\"margin:0 0 16px;padding-left:20px;\">'\n    + issues.map(function(i) { return '<li style=\"font-size:14px;color:#555;margin-bottom:4px;\">' + i + '</li>'; }).join('')\n    + '</ul>' : '')\n  + '<h4 style=\"margin:0 0 8px;\">Revision Instructions Sent to Designer</h4>'\n  + '<p style=\"margin:0 0 16px;font-size:14px;color:#333;background:#f9f9f9;padding:12px;border-radius:4px;\">' + (revision_instructions || '') + '</p>'\n  + '<p style=\"background:#f5f5f0;border-left:3px solid #C8F53A;padding:12px 16px;font-size:13px;color:#555;margin:0;\">Designer Agent has been automatically re-triggered with these revision notes. You will receive another email when the revised ebook is ready for QA.</p>'\n  + '</div>'\n  + '<div style=\"padding:16px 24px;border-top:1px solid #eee;text-align:center;\">'\n  + '<span style=\"font-size:11px;color:#aaa;\">Cipher Studio LLC &middot; Automated notification</span>'\n  + '</div>'\n  + '</div>';\n\nreturn [{ json: {\n  subject: 'QA REVISION #' + retryNum + ': ' + title + ' (score: ' + (overall_score || 0) + '/10)',\n  html\n} }];",
        "mode": "runOnceForEachItem"
      }
