    {
      "id": "qa-parse-result",
      "name": "Parse QA Result",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1880,
        600
      ],
      "parameters": {
        "jsCode": "const raw = $json.content && $json.content[0] ? $json.content[0].text.trim() : '';\nlet clean = raw;\nconst firstBrace = clean.indexOf('{');\nconst lastBrace  = clean.lastIndexOf('}');\nif (firstBrace !== -1 && lastBrace !== -1) {\n  clean = clean.substring(firstBrace, lastBrace + 1);\n}\nlet result;\ntry {\n  result = JSON.parse(clean);\n} catch (e) {\n  result = {\n    pass: false, overall_score: 0,\n    issues: ['QA JSON parse error: ' + e.message],\n    revision_instructions: 'Regenerate the ebook — QA could not parse the result.',\n    strengths: [], recommendation: 'Parse failed'\n  };\n}\n\nconst prev = $('Build QA Request').first().json;\nreturn [{ json: { ...result, productId: prev.productId, product: prev.product } }];",
        "mode": "runOnceForEachItem"
      }
    },
