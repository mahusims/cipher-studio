    {
      "id": "qa-build-request",
      "name": "Build QA Request",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1400,
        600
      ],
      "parameters": {
        "jsCode": "const product   = $('Check Retry Count').first().json.product;\nconst productId = $('Check Retry Count').first().json.productId;\nconst htmlItem  = $('Fetch Ebook HTML').first();\nconst ebookHtml = htmlItem.json.data || htmlItem.json.body || '';\n\nconst systemLines = [\n  'You are the QA Agent for Cipher Studio. Review ebooks before listing.',\n  '',\n  'Score these 4 criteria (1-10 each):',\n  '',\n  '1. CONTENT QUALITY: Practical, actionable, current facts, specific examples, substantial chapters, no filler.',\n  '2. FORMATTING: Chapter title pages + body pages + checklist per chapter, 30+ pages total, callouts/tables/stat cards used well, text not crammed.',\n  '3. BRAND CONSISTENCY: #C8F53A lime accents, #0A0A0A dark pages, Bebas Neue headings, Space Grotesk body, Cipher Studio in headers/footers/cover.',\n  '4. MARKET READINESS: Worth $10-15, competitive with top Etsy/Amazon ebooks, compelling TOC, professional feel.',\n  '',\n  'PASS requires ALL four scores >= 7.',\n  '',\n  'Return ONLY valid JSON (no markdown fences):',\n  '{',\n  '  \"pass\": true or false,',\n  '  \"overall_score\": average of 4 scores,',\n  '  \"content_score\": 0,',\n  '  \"formatting_score\": 0,',\n  '  \"brand_score\": 0,',\n  '  \"market_score\": 0,',\n  '  \"issues\": [\"specific issues if failing — be precise\"],',\n  '  \"revision_instructions\": \"Exact instructions for the Designer Agent — which pages, what to change.\",',\n  '  \"strengths\": [\"what works well\"],',\n  '  \"recommendation\": \"one sentence summary\"',\n  '}'\n];\n\nconst requestBody = JSON.stringify({\n  model: 'claude-sonnet-4-6',\n  max_tokens: 4096,\n  system: systemLines.join('\\n'),\n  messages: [{\n    role: 'user',\n    content: 'Review this ebook for Cipher Studio:\\n\\nPRODUCT: ' + product.name + ' - ' + product.description + '\\n\\nEBOOK HTML (first 30000 chars):\\n' + ebookHtml.substring(0, 30000)\n  }]\n});\n\nreturn [{ json: { requestBody, productId, product } }];"
      }
    },
    {
      "id": "qa-claude",
      "name": "Claude Sonnet — QA Review",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1640,
        600
      ],
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-api-key",
              "value": "=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"
            },
            {
              "name": "anthropic-version",
