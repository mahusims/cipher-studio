    {
      "id": "qa-retry-check",
      "name": "Check Retry Count",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        680,
        400
      ],
      "parameters": {
        "jsCode": "const items = $('Fetch Product').all();\nconst product = items.length > 0 ? (Array.isArray(items[0].json) ? items[0].json[0] : items[0].json) : {};\nconst retryCount = product.qa_retry_count || 0;\nconst productId = $('Webhook Trigger').first().json.body.product_id;\n\nreturn [{ json: { product, retryCount, shouldEscalate: retryCount >= 2, productId } }];"
      }
    },
    {
      "id": "qa-if-retries",
      "name": "IF: Max Retries",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        920,
        400
      ],
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": false,
            "leftValue": "",
            "typeValidation": "loose"
          },
          "conditions": [
            {
              "id": "retry-check",
              "leftValue": "={{ $json.shouldEscalate }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        }
      }
    },
    {
      "id": "qa-build-escalate-email",
      "name": "Build Escalation Email",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1160,
        200
      ],
      "parameters": {
        "jsCode": "const { product, retryCount, productId } = $('Check Retry Count').first().json;\nconst title = product.name || 'Unknown Ebook';\n\nconst html = '<div style=\"max-width:600px;margin:0 auto;font-family:Arial,sans-serif;color:#333;\">'\n  + '<div style=\"background:#0A0A0A;padding:24px;text-align:center;\">'\n  + '<span style=\"color:#C8F53A;font-size:18px;letter-spacing:3px;font-weight:bold;\">CIPHER STUDIO</span>'\n  + '</div>'\n  + '<div style=\"padding:24px;\">'\n  + '<h2 style=\"margin:0 0 8px;color:#c00;\">Action Required: Manual QA Review</h2>'\n  + '<p style=\"margin:0 0 16px;color:#555;\">' + title + ' has failed QA ' + retryCount + ' times. Automatic retries exhausted.</p>'\n  + '<table style=\"width:100%;margin:0 0 20px;\">'\n  + '<tr><td style=\"padding:8px 0;font-size:14px;color:#888;\">Product</td><td style=\"padding:8px 0;font-size:14px;color:#333;\">' + title + '</td></tr>'\n  + '<tr><td style=\"padding:8px 0;font-size:14px;color:#888;\">Product ID</td><td style=\"padding:8px 0;font-size:14px;color:#333;font-family:monospace;font-size:12px;\">' + productId + '</td></tr>'\n  + '<tr><td style=\"padding:8px 0;font-size:14px;color:#888;\">Failed attempts</td><td style=\"padding:8px 0;font-size:14px;color:#c00;font-weight:bold;\">' + retryCount + '</td></tr>'\n  + '</table>'\n  + '<p style=\"background:#f5f5f0;border-left:3px solid #C8F53A;padding:12px 16px;font-size:13px;color:#555;margin:0;\">Please review the PDF in Supabase Storage and either fix manually, set status to qa_passed, or delete and regenerate.</p>'\n  + '</div>'\n  + '<div style=\"padding:16px 24px;border-top:1px solid #eee;text-align:center;\">'\n  + '<span style=\"font-size:11px;color:#aaa;\">Cipher Studio LLC &middot; Automated notification</span>'\n  + '</div>'\n  + '</div>';\n\nreturn [{ json: {\n  subject: 'ACTION REQUIRED: ' + title + ' failed QA ' + retryCount + ' times',\n  html\n} }];",
        "mode": "runOnceForEachItem"
      }
    },
