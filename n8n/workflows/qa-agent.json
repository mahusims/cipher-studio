    {
      "id": "qa-build-passed-email",
      "name": "Build QA Passed Email",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2840,
        400
      ],
      "parameters": {
        "jsCode": "const qa = $('Parse QA Result').first().json;\nconst { product, productId, overall_score, content_score, formatting_score, brand_score, market_score, strengths, recommendation } = qa;\nconst title = product.name || 'Unknown Ebook';\n\nconst scoreRow = (label, score) =>\n  '<tr><td style=\"padding:6px 0;font-size:14px;color:#888;\">' + label + '</td>'\n  + '<td style=\"padding:6px 0;font-size:14px;font-weight:bold;color:#333;\">' + (score || 0) + '/10</td></tr>';\n\nconst html = '<div style=\"max-width:600px;margin:0 auto;font-family:Arial,sans-serif;color:#333;\">'\n  + '<div style=\"background:#0A0A0A;padding:24px;text-align:center;\">'\n  + '<span style=\"color:#C8F53A;font-size:18px;letter-spacing:3px;font-weight:bold;\">CIPHER STUDIO</span>'\n  + '</div>'\n  + '<div style=\"padding:24px;\">'\n  + '<h2 style=\"margin:0 0 4px;color:#0A0A0A;\">QA Passed</h2>'\n  + '<h3 style=\"margin:0 0 16px;font-size:16px;color:#333;font-weight:normal;\">' + title + '</h3>'\n  + '<p style=\"margin:0 0 20px;font-size:16px;font-weight:bold;color:#C8F53A;background:#0A0A0A;padding:12px 16px;border-radius:4px;\">Overall Score: ' + (overall_score || 0) + '/10</p>'\n  + '<table style=\"width:100%;margin:0 0 20px;\">'\n  + scoreRow('Content Quality', content_score)\n  + scoreRow('Formatting', formatting_score)\n  + scoreRow('Brand Consistency', brand_score)\n  + scoreRow('Market Readiness', market_score)\n  + '</table>'\n  + (strengths && strengths.length ? '<h4 style=\"margin:0 0 8px;\">Strengths</h4><ul style=\"margin:0 0 16px;padding-left:20px;\">'\n    + strengths.map(function(s) { return '<li style=\"font-size:14px;color:#555;margin-bottom:4px;\">' + s + '</li>'; }).join('')\n    + '</ul>' : '')\n  + '<p style=\"margin:0 0 16px;font-size:14px;color:#666;font-style:italic;\">' + (recommendation || '') + '</p>'\n  + '<p style=\"background:#f5f5f0;border-left:3px solid #C8F53A;padding:12px 16px;font-size:13px;color:#555;margin:0;\">Listing Agent has been triggered to prepare this product for sale.</p>'\n  + '</div>'\n  + '<div style=\"padding:16px 24px;border-top:1px solid #eee;text-align:center;\">'\n  + '<span style=\"font-size:11px;color:#aaa;\">Cipher Studio LLC &middot; Automated notification</span>'\n  + '</div>'\n  + '</div>';\n\nreturn [{ json: {\n  subject: 'QA PASSED: ' + title + ' (score: ' + (overall_score || 0) + '/10)',\n  html\n} }];",
        "mode": "runOnceForEachItem"
      }
